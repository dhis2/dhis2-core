<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>
    <class name="org.hisp.dhis.tracker.model.RelationshipItem" table="relationshipitem">

        <!-- L2 cache disabled while the tracker importer is being migrated to JDBC; relationship
             items are eager-fetched from Relationship, so stale entries here would surface as
             stale relationship reads. Re-enable once the importer no longer touches relationship
             items via Hibernate. -->

        <id name="id" column="relationshipitemid">
            <generator class="sequence">
                <param name="sequence_name">relationshipitem_sequence</param>
            </generator>
        </id>

        <many-to-one name="relationship" class="org.hisp.dhis.tracker.model.Relationship"
                     column="relationshipid"
                     foreign-key="fk_relationshipitem_relationshipid"
                        cascade="delete"/>

        <many-to-one name="trackedEntity" class="org.hisp.dhis.tracker.model.TrackedEntity"
                     column="trackedentityid"
                     foreign-key="fk_relationshipitem_trackedentityinstanceid"/>

        <many-to-one name="enrollment" class="org.hisp.dhis.tracker.model.Enrollment"
                     column="enrollmentid"
                     foreign-key="fk_relationshipitem_programinstanceid"/>

        <many-to-one name="trackerEvent" class="org.hisp.dhis.tracker.model.TrackerEvent"
                     column="trackereventid"
                     foreign-key="fk_relationshipitem_trackereventid"/>

        <many-to-one name="singleEvent" class="org.hisp.dhis.tracker.model.SingleEvent"
                     column="singleeventid"
                     foreign-key="fk_relationshipitem_singleeventid"/>
    </class>
</hibernate-mapping>
